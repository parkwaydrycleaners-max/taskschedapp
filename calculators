<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Dress Hem Calculator</title>
<style>
  body {
    font-family: Arial, sans-serif;
    max-width: 500px;
    margin: auto;
    padding: 20px;
  }
  h2 { text-align: center; }
  label { display: block; margin-top: 15px; font-weight: bold; }
  input {
    width: 100%;
    padding: 8px;
    margin-top: 5px;
    box-sizing: border-box;
  }
  button {
    margin-top: 20px;
    width: 100%;
    padding: 10px;
    font-size: 1.2rem;
  }
  .total {
    margin-top: 20px;
    font-size: 1.4rem;
    font-weight: bold;
    text-align: center;
  }
</style>
</head>

<body>
<h2>Dress Hem Calculator</h2>

<label>Dress Hems (12.50 per yard)</label>
<input type="number" id="hemYards" placeholder="Enter yards" min="0" step="0.1" />

<label>Dress Cut Hems (6.25 per yard)</label>
<input type="number" id="cutHemYards" placeholder="Enter yards" min="0" step="0.1" />

<label>Dress Hems with Horsehair (25.00 per yard)</label>
<input type="number" id="horsehairYards" placeholder="Enter yards" min="0" step="0.1" />

<button onclick="calculateTotal()">Calculate Total</button>

<div class="total" id="total">Total: $0.00</div>

<script>
function calculateTotal() {
  const hemPrice = 12.5;
  const cutHemPrice = 6.25;
  const horsehairPrice = 25;

  const hemYards = parseFloat(document.getElementById('hemYards').value) || 0;
  const cutHemYards = parseFloat(document.getElementById('cutHemYards').value) || 0;
  const horsehairYards = parseFloat(document.getElementById('horsehairYards').value) || 0;

  const total =
    hemYards * hemPrice +
    cutHemYards * cutHemPrice +
    horsehairYards * horsehairPrice;

  document.getElementById('total').innerText =
    "Total: $" + total.toFixed(2);
}
</script>

</body>
</html>
